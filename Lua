-- **JUMPING LOADING (15-20s TOTAL)**
local startTime = tick()
local totalDuration = math.random(15, 20)  -- Random 15-20 seconds

task.spawn(function()
    local currentPercent = 0
    
    while currentPercent < 100 and tick() - startTime < totalDuration do
        -- Jump logic: Fast jumps early, slow near end
        local timeElapsed = tick() - startTime
        local progress = math.min(timeElapsed / totalDuration, 0.95)  -- 95% smooth
        
        local targetPercent = math.floor(progress * 100)
        
        -- Add jumps every 2-3 seconds
        if timeElapsed % math.random(2, 3) < 0.1 then
            targetPercent = math.min(targetPercent + math.random(3, 8), 95)
        end
        
        if targetPercent > currentPercent then
            currentPercent = targetPercent
            
            -- Smooth bar animation
            TweenService:Create(barFill, TweenInfo.new(0.6, Enum.EasingStyle.Quart), 
                {Size = UDim2.new(currentPercent/100, 0, 1, 0)}):Play()
            
            percentLabel.Text = currentPercent .. "%"
            
            if currentPercent % 15 == 0 then
                glitchEffect()
            end
        end
        
        task.wait(0.2)
    end
    
    -- FINAL RUSH TO 100%
    for i = math.floor(currentPercent), 100 do
        currentPercent = i
        TweenService:Create(barFill, TweenInfo.new(0.3), 
            {Size = UDim2.new(1, 0, 1, 0)}):Play()
        percentLabel.Text = "100%"
        glitchEffect()
        task.wait(0.4)
    end
    
    -- **EXECUTE SECOND SCRIPT**
    task.wait(1)
    loadstring(SECOND_SCRIPT)()
    
    -- Fade out loader
    TweenService:Create(mainFrame, TweenInfo.new(2), {BackgroundTransparency = 1}):Play()
    task.wait(2)
    screenGui:Destroy()
end)

