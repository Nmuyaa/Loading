-- Create floating brainrot particles
local function createParticle()
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(4, 12), 0, math.random(4, 12))
    particle.Position = UDim2.new(math.random(), 0, 1, math.random(-50, 0))
    particle.BackgroundColor3 = Color3.fromRGB(math.random(150, 255), math.random(0, 100), math.random(200, 255))
    particle.BorderSizePixel = 0
    particle.ZIndex = 1
    particle.Parent = particles
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle
    
    -- Float up animation
    local tween = TweenService:Create(particle, 
        TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
        {Position = UDim2.new(math.random(), 0, -0.2, 0), BackgroundTransparency = 1}
    )
    tween:Play()
    tween.Completed:Connect(function() particle:Destroy() end)
end

-- Spawn particles continuously
task.spawn(function()
    while true do
        createParticle()
        task.wait(math.random(8, 15)/10)
    end
end)

-- Glitch Effect Function
local function glitchEffect()
    task.spawn(function()
        glitchOverlay.BackgroundTransparency = 0.9
        local glitchTween = TweenService:Create(glitchOverlay, 
            TweenInfo.new(0.05, Enum.EasingStyle.Quad),
            {BackgroundTransparency = 1}
        )
        glitchTween:Play()
    end)
end

-- Main Loading Logic
local currentPercent = 0
local targetPercent = 0

-- Update function
local function updateLoading(percent)
    targetPercent = percent
    local barTween = TweenService:Create(barFill, 
        TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Size = UDim2.new(percent/100, 0, 1, 0)}
    )
    barTween:Play()
    
    percentLabel.Text = percent .. "%"
    
    -- Rainbow effect on percent text
    local hue = (percent / 100)
    percentLabel.TextColor3 = Color3.fromHSV(hue, 1, 1)
    
    -- Glitch at certain percentages
    if percent % 10 == 0 then
        glitchEffect()
    end
end

-- Loading loop (1% per second, stops at 99%)
task.spawn(function()
    for i = 1, 99 do
        updateLoading(i)
        task.wait(1)  -- 1 second per percent
    end
    -- STAYS AT 99% FOREVER - Script remains loaded
end)

